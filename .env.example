# =====================================================================
# Variables de entorno — ChurnLens
# Copia este archivo a `.env` y ajusta según tu entorno.
# El archivo `.env` está ignorado por git.
# =====================================================================

# --- Logging ---------------------------------------------------------
# Nivel de log raíz: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Formato del log: console | json
LOG_FORMAT=console

# --- Datos -----------------------------------------------------------
# URL pública del dataset Telco Customer Churn.
# Fuente primaria: mirror oficial de IBM en GitHub.
CHURNLENS_DATA_URL=https://raw.githubusercontent.com/IBM/telco-customer-churn-on-icp4d/master/data/Telco-Customer-Churn.csv

# Nombre del archivo crudo guardado en data/raw/
CHURNLENS_RAW_FILENAME=telco_customer_churn.csv

# Hash MD5 esperado del archivo crudo (se verifica al descargar).
# Si está vacío, se omite la verificación.
CHURNLENS_RAW_MD5=

# --- Reproducibilidad ------------------------------------------------
CHURNLENS_RANDOM_SEED=42

# --- Rutas (overrides para contenedores / CI) -------------------------
# Por defecto se infieren desde la raíz del proyecto; en Docker se fijan
# a /app/data y /app/models (ver Dockerfile).
# CHURNLENS_DATA_DIR=/app/data
# CHURNLENS_MODELS_DIR=/app/models

# --- Serving (Fase 4) --------------------------------------------------
# Modelo registrado que expone la API de inferencia.
CHURNLENS_SERVING_MODEL=logreg_l1

# Threshold de decisión. Si se omite, se usa el sintonizado en Fase 3
# (0.58, registrado en models/logreg_l1.metadata.json).
# CHURNLENS_SERVING_THRESHOLD=0.58

# Interfaz y puerto de la API (0.0.0.0 en contenedores).
CHURNLENS_API_HOST=127.0.0.1
CHURNLENS_API_PORT=8000
