# =====================================================================
# Variables de entorno — ChurnLens
# Copia este archivo a `.env` y ajusta según tu entorno.
# El archivo `.env` está ignorado por git.
# =====================================================================

# --- Logging ---------------------------------------------------------
# Nivel de log raíz: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Formato del log: console | json
LOG_FORMAT=console

# --- Datos -----------------------------------------------------------
# URL pública del dataset Telco Customer Churn.
# Fuente primaria: mirror oficial de IBM en GitHub.
CHURNLENS_DATA_URL=https://raw.githubusercontent.com/IBM/telco-customer-churn-on-icp4d/master/data/Telco-Customer-Churn.csv

# Nombre del archivo crudo guardado en data/raw/
CHURNLENS_RAW_FILENAME=telco_customer_churn.csv

# Hash MD5 esperado del archivo crudo (se verifica al descargar).
# Si está vacío, se omite la verificación.
CHURNLENS_RAW_MD5=

# --- Reproducibilidad ------------------------------------------------
CHURNLENS_RANDOM_SEED=42
